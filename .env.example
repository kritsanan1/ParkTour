
# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL (Required)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?ssl=true
# Example for Neon Database (recommended for production)
DATABASE_URL="postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/tourderwang?ssl=true"

# Example for local development
# DATABASE_URL="postgresql://postgres:password@localhost:5432/tourderwang_dev"

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# Session Secret (Required)
# Generate a secure random string for session encryption
# Use: openssl rand -base64 32
SESSION_SECRET="your-super-secure-session-secret-min-32-chars-long"

# Replit Auth Configuration (Required for production deployment)
# Get these from Replit Auth setup: https://replit.com/auth
REPLIT_AUTH_CLIENT_ID="your-replit-auth-client-id"
REPLIT_AUTH_CLIENT_SECRET="your-replit-auth-client-secret"

# OAuth Callback URL (adjust for your domain)
REPLIT_AUTH_CALLBACK_URL="https://your-app-name.repl.co/api/auth/callback"

# =============================================================================
# STRIPE PAYMENT CONFIGURATION
# =============================================================================

# Stripe Secret Key (Required for payment processing)
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys for development (sk_test_...) and live keys for production (sk_live_...)
STRIPE_SECRET_KEY="sk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Stripe Publishable Key (Required for frontend)
# This will be included in client-side code, so test keys are safe for development
STRIPE_PUBLISHABLE_KEY="pk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Stripe Webhook Secret (Required for payment webhooks)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Environment (Required)
# Values: development | production | test
NODE_ENV="development"

# Server Port (Optional - defaults to 5000)
# Replit uses port 5000 by default, only change if needed
PORT="5000"

# Application Base URL (Required for OAuth and webhooks)
# Development: http://localhost:5000
# Production: https://your-app-name.repl.co
APP_BASE_URL="http://localhost:5000"

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Email Service Configuration (Optional - for notifications)
# Example with SendGrid
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# FROM_EMAIL="noreply@tourderwang.com"

# Image Upload Service (Optional - for business images)
# Example with Cloudinary
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="123456789012345"
# CLOUDINARY_API_SECRET="your-cloudinary-secret"

# Google Maps API (Optional - for location services)
# GOOGLE_MAPS_API_KEY="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# =============================================================================
# LOGGING AND MONITORING (Optional)
# =============================================================================

# Log Level (Optional - defaults to 'info')
# Values: error | warn | info | debug
LOG_LEVEL="info"

# Enable Performance Monitoring (Optional - defaults to false)
ENABLE_PERFORMANCE_MONITORING="true"

# Sentry Error Tracking (Optional)
# SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable Development Features (Optional)
ENABLE_DEV_TOOLS="true"

# Mock External Services (Optional - for development)
MOCK_STRIPE_PAYMENTS="false"
MOCK_EMAIL_SERVICE="true"

# Database Seeding (Optional - for development)
SEED_DATABASE="true"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Origin (Optional - defaults to same origin)
# For development with separate frontend: http://localhost:3000
# For production: https://your-domain.com
# CORS_ORIGIN="http://localhost:3000"

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW_MS="900000"    # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"    # Max requests per window

# Cookie Security (Optional)
SECURE_COOKIES="false"           # Set to true in production with HTTPS
SAME_SITE_COOKIES="lax"          # lax | strict | none

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================

# Enable/disable specific features
ENABLE_VIRTUAL_TOURS="true"
ENABLE_PREMIUM_FEATURES="true"
ENABLE_REVIEWS_SYSTEM="true"
ENABLE_ANALYTICS="true"

# =============================================================================
# THAI LOCALIZATION (Optional)
# =============================================================================

# Default Language (Optional - defaults to 'th')
DEFAULT_LANGUAGE="th"

# Enable Bilingual Support (Optional - defaults to true)
ENABLE_BILINGUAL="true"

# =============================================================================
# PERFORMANCE OPTIMIZATION (Optional)
# =============================================================================

# Enable Caching (Optional)
ENABLE_REDIS_CACHE="false"
REDIS_URL="redis://localhost:6379"

# Enable CDN (Optional)
CDN_BASE_URL="https://cdn.tourderwang.com"

# =============================================================================
# BACKUP AND MAINTENANCE (Optional)
# =============================================================================

# Database Backup (Optional)
# BACKUP_SCHEDULE="0 2 * * *"    # Daily at 2 AM
# BACKUP_RETENTION_DAYS="30"

# Maintenance Mode (Optional)
MAINTENANCE_MODE="false"
MAINTENANCE_MESSAGE="เว็บไซต์อยู่ระหว่างการปรับปรุง กรุณาเข้าใช้งานใหม่ในภายหลัง"

# =============================================================================
# ADDITIONAL NOTES
# =============================================================================

# 1. Never commit .env file to version control
# 2. Use different values for development, staging, and production
# 3. Regularly rotate secrets and API keys
# 4. Test all configurations before deploying to production
# 5. Use environment-specific .env files (.env.local, .env.production, etc.)

# For Replit Deployment:
# - Set these variables in Replit Secrets (not in .env file)
# - Required variables: DATABASE_URL, SESSION_SECRET, STRIPE_SECRET_KEY
# - Optional but recommended: All auth and external service keys

# Security Checklist:
# ✅ Strong SESSION_SECRET (32+ characters)
# ✅ Production Stripe keys for live deployment
# ✅ Proper DATABASE_URL with SSL
# ✅ Correct callback URLs for OAuth
# ✅ HTTPS enabled for production (SECURE_COOKIES=true)
